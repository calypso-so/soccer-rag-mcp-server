# Optional BYOK override for upload tools and custom Calypso teams
# CALYPSO_API_KEY=sk-your-calypso-api-key-here

# Public demo MCP bearer used in zero-config mode (default built-in token works with AIcore)
# CALYPSO_DEMO_MCP_BEARER=sk-demo-mcp-worldcup-calypso-public-demo-v1

# Base URL for the Calypso OpenAI-compatible API (must end in /v1)
CALYPSO_API_BASE_URL=https://api.calypso.so/v1
